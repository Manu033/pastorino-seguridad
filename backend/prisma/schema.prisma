generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoFuente {
  EXCEL
  PDF
  API
  MANUAL
}

enum Moneda {
  ARS
  USD
}

enum TipoItemCotizacion {
  PRODUCTO
  MANUAL
}

enum TipoCotizacion {
  EXTINCION
  DETECCION
  SALA_BOMBAS
}

enum RedondeoCompra {
  ARRIBA
}

enum EstadoCotizacion {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum FormulaAccesorioAutomatico {
  PERA
  SOPORTE
  ACOPLE
}

model Proveedor {
  id                  Int                 @id @default(autoincrement())
  nombre              String              @unique @db.VarChar(150)
  email_contacto      String?             @db.VarChar(255)
  telefono            String?             @db.VarChar(80)
  tipo_fuente         TipoFuente
  tipos               TipoCotizacion[]
  activo              Boolean             @default(true)
  productos_proveedor ProductoProveedor[]

  @@map("proveedores")
}

model Categoria {
  id                   Int                  @id @default(autoincrement())
  nombre               String               @unique @db.VarChar(120)
  tipos                TipoCotizacion[]
  subcategorias        Subcategoria[]
  productos_proveedor  ProductoProveedor[]
  productos_compuestos ProductoCompuesto[]

  @@map("categorias")
}

model Subcategoria {
  id                  Int                 @id @default(autoincrement())
  id_categoria        Int
  nombre              String              @db.VarChar(120)
  categoria           Categoria           @relation(fields: [id_categoria], references: [id])
  productos_proveedor ProductoProveedor[]
  productos_compuestos ProductoCompuesto[]

  @@unique([id_categoria, nombre], name: "uq_subcategorias_categoria_nombre")
  @@index([id_categoria])
  @@map("subcategorias")
}

model ProductoProveedor {
  id                         Int               @id @default(autoincrement())
  id_proveedor               Int
  id_categoria               Int?
  id_subcategoria            Int?
  sku_producto_proveedor     String            @db.VarChar(120)
  nombre_producto_proveedor  String            @db.VarChar(255)
  marca_producto_proveedor   String?           @db.VarChar(120)
  modelo_producto_proveedor  String?           @db.VarChar(120)
  descripcion                String?
  imagen_url                 String?           @db.VarChar(500)
  unidad                     String?           @db.VarChar(40)
  unidad_calculo             String?           @db.VarChar(40)
  cantidad_por_unidad_compra Decimal?          @db.Decimal(14, 4)
  redondeo_compra            RedondeoCompra?
  precio_actual              Decimal?          @db.Decimal(14, 4)
  moneda_actual              Moneda?
  fecha_precio_actualizada   DateTime?
  activo                     Boolean           @default(true)
  proveedor                  Proveedor         @relation(fields: [id_proveedor], references: [id])
  categoria                  Categoria?        @relation(fields: [id_categoria], references: [id])
  subcategoria               Subcategoria?     @relation(fields: [id_subcategoria], references: [id])
  historial_precios          HistorialPrecio[]
  cotizacion_items           CotizacionItem[]
  compuesto_items            ProductoCompuestoItem[]
  accesorios_automaticos_tubo ProductoAccesorioAutomatico[] @relation("ProductoTuboAccesorioAutomatico")
  accesorios_automaticos      ProductoAccesorioAutomatico[] @relation("ProductoAccesorioAutomatico")

  @@unique([id_proveedor, sku_producto_proveedor], name: "uq_productos_proveedor_proveedor_sku")
  @@index([id_proveedor])
  @@index([id_categoria])
  @@index([id_subcategoria])
  @@index([sku_producto_proveedor])
  @@map("productos_proveedor")
}

model Cotizacion {
  id                         Int              @id @default(autoincrement())
  tipo                       TipoCotizacion   @default(EXTINCION)
  titulo                     String           @db.VarChar(180)
  cliente                    String?          @db.VarChar(180)
  contacto_cliente           String?          @db.VarChar(180)
  cuit_cliente               String?          @db.VarChar(80)
  email_cliente              String?          @db.VarChar(255)
  obra                       String?          @db.VarChar(180)
  telefono_obra              String?          @db.VarChar(80)
  fecha_emision              DateTime?
  validez_dias               Int?             @default(30)
  moneda_base                Moneda           @default(USD)
  observaciones              String?
  dolar_referencia           Decimal?         @db.Decimal(14, 4)
  costo_directo_usd          Decimal          @default(0) @db.Decimal(14, 4)
  porcentaje_utilidad        Decimal          @default(0) @db.Decimal(8, 4)
  monto_utilidad_usd         Decimal          @default(0) @db.Decimal(14, 4)
  subtotal_usd               Decimal          @default(0) @db.Decimal(14, 4)
  aplica_costos_varios       Boolean          @default(false)
  porcentaje_costos_varios   Decimal          @default(0) @db.Decimal(8, 4)
  monto_costos_varios_usd    Decimal          @default(0) @db.Decimal(14, 4)
  total_usd                  Decimal          @db.Decimal(14, 4)
  estado                     EstadoCotizacion @default(PENDIENTE)
  creada_en                  DateTime         @default(now())
  items                      CotizacionItem[]

  @@index([creada_en])
  @@index([tipo])
  @@index([estado])
  @@map("cotizaciones")
}

model CotizacionItem {
  id                    Int                @id @default(autoincrement())
  id_cotizacion         Int
  id_producto_proveedor Int?
  tipo                  TipoItemCotizacion
  descripcion           String             @db.VarChar(500)
  cantidad              Decimal            @db.Decimal(14, 4)
  unidad                String?            @db.VarChar(40)
  precio_unitario       Decimal            @db.Decimal(14, 4)
  moneda                Moneda
  total_usd             Decimal            @db.Decimal(14, 4)
  metros_requeridos     Decimal?           @db.Decimal(14, 4)
  generado_automaticamente Boolean          @default(false)
  formula_automatica    FormulaAccesorioAutomatico?
  cotizacion            Cotizacion         @relation(fields: [id_cotizacion], references: [id], onDelete: Cascade)
  producto_proveedor    ProductoProveedor? @relation(fields: [id_producto_proveedor], references: [id], onDelete: SetNull)

  @@index([id_cotizacion])
  @@index([id_producto_proveedor])
  @@map("cotizacion_items")
}

model ProductoAccesorioAutomatico {
  id                    Int                         @id @default(autoincrement())
  id_producto_tubo      Int
  id_producto_accesorio Int
  formula               FormulaAccesorioAutomatico
  separacion_maxima_m   Decimal?                    @db.Decimal(14, 4)
  activo                Boolean                     @default(true)
  producto_tubo         ProductoProveedor           @relation("ProductoTuboAccesorioAutomatico", fields: [id_producto_tubo], references: [id], onDelete: Cascade)
  producto_accesorio    ProductoProveedor           @relation("ProductoAccesorioAutomatico", fields: [id_producto_accesorio], references: [id], onDelete: Cascade)

  @@unique([id_producto_tubo, id_producto_accesorio, formula], name: "uq_productos_accesorios_automaticos")
  @@index([id_producto_tubo])
  @@index([id_producto_accesorio])
  @@map("productos_accesorios_automaticos")
}

model HistorialPrecio {
  id                    Int               @id @default(autoincrement())
  id_producto_proveedor Int
  precio                Decimal           @db.Decimal(14, 4)
  moneda                Moneda
  fecha_actualizada     DateTime          @default(now())
  producto_proveedor    ProductoProveedor @relation(fields: [id_producto_proveedor], references: [id], onDelete: Cascade)

  @@index([id_producto_proveedor])
  @@index([fecha_actualizada])
  @@map("historial_precios")
}

model ProductoCompuesto {
  id              Int                     @id @default(autoincrement())
  id_categoria    Int?
  id_subcategoria Int?
  nombre          String                  @unique @db.VarChar(255)
  descripcion     String?
  activo          Boolean                 @default(true)
  categoria       Categoria?              @relation(fields: [id_categoria], references: [id])
  subcategoria    Subcategoria?           @relation(fields: [id_subcategoria], references: [id])
  items           ProductoCompuestoItem[]

  @@index([id_categoria])
  @@index([id_subcategoria])
  @@map("productos_compuestos")
}

model ProductoCompuestoItem {
  id                    Int                @id @default(autoincrement())
  id_producto_compuesto Int
  tipo                  TipoItemCotizacion
  id_producto_proveedor Int?
  descripcion           String             @db.VarChar(500)
  cantidad              Decimal            @db.Decimal(14, 4)
  unidad                String?            @db.VarChar(40)
  precio_unitario       Decimal?           @db.Decimal(14, 4)
  moneda                Moneda?
  producto_compuesto    ProductoCompuesto  @relation(fields: [id_producto_compuesto], references: [id], onDelete: Cascade)
  producto_proveedor    ProductoProveedor? @relation(fields: [id_producto_proveedor], references: [id], onDelete: SetNull)

  @@index([id_producto_compuesto])
  @@index([id_producto_proveedor])
  @@map("productos_compuestos_items")
}
